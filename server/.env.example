# FrameQ account and billing service configuration.
# Do not commit real secrets.

FRAMEQ_SERVER_HOST=127.0.0.1
FRAMEQ_SERVER_PORT=8787
DATABASE_URL=file:./data/frameq.sqlite

# SMTP email OTP delivery. If omitted, development mode prints OTPs to stdout.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# WeChat Pay Native payment. If omitted, checkout returns a development code_url.
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_MCH_SERIAL_NO=
WECHAT_MCH_PRIVATE_KEY=
WECHAT_NOTIFY_URL=

# WeChat APIv3 notification verification. Production requires both values.
WECHAT_API_V3_KEY=
WECHAT_PLATFORM_CERT_PEM=

# Development only: accepts simple unsigned JSON payment notifications.
WECHAT_DEV_INSECURE_NOTIFY=0

